{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "australiaeast"
    },
    "vmName": {
      "value": "vinay-vm"
    },
    "adminUsername": {
      "value": "azureuser"
    },
    "sshPublicKey": {
      "value": ""
    },
    "vmSize": {
      "value": "Standard_B2ats_v2"
    },
    "vnetName": {
      "value": "vinay-vnet"
    },
    "subnetName": {
      "value": "vinay-subnet"
    },
    "addressPrefix": {
      "value": "10.0.0.0/16"
